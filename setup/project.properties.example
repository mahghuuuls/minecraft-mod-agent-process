# Copy this file to workspace/project.properties only after replacing required values.
# For Initial Development, this file may be deferred until project identity is known.
# Existing Mod Assessment and Change Cycle identify the existing repository.

# Repository identity:
github_username=
repository_name=
project_repository_url=
project_directory_name=

# Mod identity:
mod_id=
display_name=
public_mod_description=
# Recommended default: com.<github-owner>.<mod-id>
root_package=
# Recommended default: <PascalCaseDisplayName>Mod
main_class=
mod_authors=
minecraft_username=

# Project platform and distribution decisions:
mod_loader=
supported_runtimes=
distribution_platforms=curseforge
mod_runtime_role=

# Approved template for Initial Development:
template_repository_url=
template_repository_ref=

# Documentation and collaboration preferences:
public_documentation_style=player-facing
commit_message_style=repo-facing-no-workflow-issue-references

# Release handoff mode:
# Allowed values: owner-managed-packaging, agent-managed-release-validation
release_handoff_mode=agent-managed-release-validation

# Release ownership matrix:
# Allowed values: agent, owner, shared, deferred
release_owner_readme=agent
release_owner_changelog=agent
release_owner_icon=owner
release_owner_screenshots=owner
release_owner_curseforge_upload=owner
release_owner_release_jar_generation=agent
release_owner_final_publication_verification=agent
release_owner_dedicated_server_testing=owner
release_owner_cleanroom_testing=owner
release_owner_external_multiplayer_testing=owner

# Optional project-specific overrides:
# preferred_development_java_version=25
# target_java_version=8
# project_default_branch=main
# root_package_pattern=com.{github_owner}.{mod_id}
# main_class_pattern={PascalCaseDisplayName}Mod
# use_modern_java_syntax=false
# license=MIT
